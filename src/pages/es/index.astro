---
import Layout from "@layout/Layout.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout
  title={t("title")}
  logo={t("logo")}
  {lang}
  description={t("description")}
  flagUrl="/en"
>
  <section
    class="hero flex flex-col items-center justify-center h-full min-h-screen w-full max-w-1/2 mx-auto"
  >
    <h1 class="text-4xl font-bold text-violet-600 text-center">
      {t("title")}
    </h1>
    <p class="text-center font-semibold mt-10">
      {t("description")}
    </p>
  </section>
</Layout>

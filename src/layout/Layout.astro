---
import BaseHead from "../components/BaseHead.astro";
const {
  lang = "es",
  flagIcon = "cif:mx",
  flagUrl = "/en",
  logo,
  title,
  description,
  image = "/images/portada.png",
} = Astro.props;
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <header
      class="flex items-center justify-between px-4 py-6 shadow-md w-full"
    >
      <div class="flex items-center w-full gap-4">
        <nav class="flex items-center justify-between w-full">
          <a href="/" class="text-2xl font-bold text-gray-800">{logo}</a>
          <ul class="flex space-x-4">
            <li class="text-gray-600 hover:text-gray-800 transition-colors">
              <a href="/pokemons">poke api</a>
            </li>
            <li class="text-gray-600 hover:text-gray-800 transition-colors">
              <a href="/blog">blog</a>
            </li>
          </ul>
        </nav>
        <a href={flagUrl}  class="cursor-pointer flex items-center gap-1 hover:opacity-80 transition-opacity">
          <iconify-icon icon={flagIcon} width="23.5" height="15"></iconify-icon>
        </a>
      </div>
    </header>
    <slot />
  </body>
</html>
